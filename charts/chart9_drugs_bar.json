      },
      {
        "drug": "Hallucinogens",
        "rate": 2.4,
        "category": "Illicit"
      },
      {
        "drug": "Pain-killers/opioids",
        "rate": 2.2,
        "category": "Pharmaceutical"
      },
      {
        "drug": "Ecstasy/MDMA",
