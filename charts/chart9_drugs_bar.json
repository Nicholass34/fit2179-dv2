  "layer": [
    {
      "mark": {
        "type": "bar",
        "cornerRadiusEnd": 3,
        "height": {
          "band": 0.75
        }
      },
      "encoding": {
        "y": {
          "field": "drug",
          "type": "nominal",
          "sort": [
            "Cannabis",
            "Cocaine",
            "Hallucinogens",
            "Pain-killers/opioids",
            "Ecstasy/MDMA",
            "Pharma stimulants",
            "Tranquillisers",
            "Inhalants",
            "Ketamine",
            "Meth/amphetamine",
            "Heroin"
          ],
          "title": null,
          "axis": {
            "labelFontSize": 12,
            "labelColor": "#333",
            "domain": false,
            "ticks": false,
            "labelPadding": 8
          }
        },
        "x": {
          "field": "rate",
          "type": "quantitative",
          "title": "Used in past 12 months (%)",
          "scale": {
            "domain": [
              0,
              13
            ]
          },
          "axis": {
            "values": [
              0,
              2,
              4,
              6,
              8,
              10,
              12
            ],
            "labelExpr": "datum.value + '%'",
            "labelFontSize": 11,
            "labelColor": "#555",
            "titleFontSize": 12,
            "titleColor": "#333",
            "domain": false,
            "ticks": false,
            "grid": true,
            "gridColor": "#EEE",
            "gridDash": [
              2,
              2
            ],
            "titlePadding": 12
          }
        },
        "color": {
          "field": "category",
          "type": "nominal",
          "scale": {
            "domain": [
              "Illicit",
              "Pharmaceutical"
            ],
            "range": [
              "#C04040",
              "#9B7B3D"
            ]
          },
          "legend": {
            "orient": "top",
            "title": null,
            "labelFontSize": 12,
            "symbolType": "square",
            "symbolSize": 200,
            "padding": 8
          }
        },
        "tooltip": [
          {
            "field": "drug",
            "type": "nominal",
            "title": "Drug type"
          },
          {
            "field": "rate",
            "type": "quantitative",
            "title": "Used past year (%)"
          },
          {
            "field": "category",
            "type": "nominal",
            "title": "Category"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "fontSize": 11,
        "fontWeight": 600,
        "color": "#333",
        "align": "left",
        "dx": 6
      },
      "encoding": {
        "y": {
          "field": "drug",
          "type": "nominal",
          "sort": [
            "Cannabis",
            "Cocaine",
            "Hallucinogens",
            "Pain-killers/opioids",
            "Ecstasy/MDMA",
            "Pharma stimulants",
            "Tranquillisers",
            "Inhalants",
            "Ketamine",
            "Meth/amphetamine",
            "Heroin"
          ]
        },
        "x": {
          "field": "rate",
          "type": "quantitative"
        },
        "text": {
          "field": "rate",
          "format": ".1f"
        }
      }
    }
  ]
