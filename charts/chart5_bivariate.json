{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Two risk factors at once: smoking × drinking by state",
    "subtitle": "How states compare on both daily smoking and risky alcohol consumption, NDSHS 2022–23",
    "anchor": "start",
    "fontSize": 20,
    "subtitleFontSize": 13,
    "subtitleColor": "#666",
    "offset": 20
  },
  "config": {
    "view": {
      "stroke": null
    },
    "font": "sans-serif"
  },
  "background": "#FAFAF7",
  "padding": {
    "left": 20,
    "right": 20,
    "top": 10,
    "bottom": 30
  },
  "hconcat": [
    {
      "width": 600,
      "height": 480,
      "projection": {
        "type": "identity",
        "reflectY": true
      },
      "layer": [
        {
          "data": {
            "url": "data/australia_states.geojson",
            "format": {
              "type": "json",
              "property": "features"
            }
          },
          "transform": [
            {
              "lookup": "properties.STATE_NAME",
              "from": {
                "data": {
                  "values": [
                    {
                      "state": "NSW",
                      "smoke": 7.5,
                      "drink": 31.2,
                      "bivariate_label": "Low smoking, Low drinking",
                      "color": "#E8DDF4",
                      "state_name": "New South Wales"
                    },
                    {
                      "state": "Vic",
                      "smoke": 7.6,
                      "drink": 26.4,
                      "bivariate_label": "Low smoking, Low drinking",
                      "color": "#E8DDF4",
                      "state_name": "Victoria"
                    },
                    {
                      "state": "Qld",
                      "smoke": 10.5,
                      "drink": 33.1,
                      "bivariate_label": "High smoking, Mid drinking",
                      "color": "#735E8E",
                      "state_name": "Queensland"
                    },
                    {
                      "state": "WA",
                      "smoke": 7.7,
                      "drink": 33.2,
                      "bivariate_label": "Low smoking, Mid drinking",
                      "color": "#C8B8D9",
                      "state_name": "Western Australia"
                    },
                    {
                      "state": "SA",
                      "smoke": 9.0,
                      "drink": 32.2,
                      "bivariate_label": "Mid smoking, Mid drinking",
                      "color": "#A899B8",
                      "state_name": "South Australia"
                    },
                    {
                      "state": "Tas",
                      "smoke": 11.3,
                      "drink": 34.0,
                      "bivariate_label": "High smoking, High drinking",
                      "color": "#3D2A60",
                      "state_name": "Tasmania"
                    },
                    {
                      "state": "ACT",
                      "smoke": 4.8,
                      "drink": 26.8,
                      "bivariate_label": "Low smoking, Low drinking",
                      "color": "#E8DDF4",
                      "state_name": "Australian Capital Territory"
                    },
                    {
                      "state": "NT",
                      "smoke": 13.1,
                      "drink": 40.4,
                      "bivariate_label": "High smoking, High drinking",
                      "color": "#3D2A60",
                      "state_name": "Northern Territory"
                    }
                  ]
                },
                "key": "state_name",
                "fields": [
                  "state",
                  "smoke",
                  "drink",
                  "color",
                  "bivariate_label"
                ]
              }
            }
          ],
          "mark": {
            "type": "geoshape",
            "stroke": "white",
            "strokeWidth": 1.5
          },
          "encoding": {
            "color": {
              "field": "color",
              "type": "nominal",
              "scale": null,
              "legend": null
            },
            "tooltip": [
              {
                "field": "state",
                "type": "nominal",
                "title": "State"
              },
              {
                "field": "smoke",
                "type": "quantitative",
                "title": "Daily smoking (%)"
              },
              {
                "field": "drink",
                "type": "quantitative",
                "title": "Risky drinking (%)"
              },
              {
                "field": "bivariate_label",
                "type": "nominal",
                "title": "Category"
              }
            ]
          }
        },
        {
          "data": {
            "values": [
              {
                "lon": 121.5,
                "lat": -25.5,
                "label": "WA",
                "textColor": "#3D2A60"
              },
              {
                "lon": 133.5,
                "lat": -19.5,
                "label": "NT",
                "textColor": "white"
              },
              {
                "lon": 135.0,
                "lat": -30.0,
                "label": "SA",
                "textColor": "white"
              },
              {
                "lon": 145.0,
                "lat": -22.5,
                "label": "QLD",
                "textColor": "white"
              },
              {
                "lon": 146.8,
                "lat": -32.3,
                "label": "NSW",
                "textColor": "#3D2A60"
              },
              {
                "lon": 143.5,
                "lat": -36.8,
                "label": "VIC",
                "textColor": "#3D2A60"
              },
              {
                "lon": 146.6,
                "lat": -41.8,
                "label": "TAS",
                "textColor": "white"
              }
            ]
          },
          "mark": {
            "type": "text",
            "fontSize": 13,
            "fontWeight": 600
          },
          "encoding": {
            "longitude": {
              "field": "lon",
              "type": "quantitative"
            },
            "latitude": {
              "field": "lat",
              "type": "quantitative"
            },
            "text": {
              "field": "label"
            },
            "color": {
              "field": "textColor",
              "type": "nominal",
              "scale": null,
              "legend": null
            }
          }
        },
        {
          "data": {
            "values": [
              {
                "x1": 149.1,
                "y1": -35.5,
                "x2": 152.8,
                "y2": -34.5
              }
            ]
          },
          "mark": {
            "type": "rule",
            "stroke": "#888",
            "strokeWidth": 0.8,
            "strokeDash": [
              2,
              2
            ]
          },
          "encoding": {
            "longitude": {
              "field": "x1",
              "type": "quantitative"
            },
            "latitude": {
              "field": "y1",
              "type": "quantitative"
            },
            "longitude2": {
              "field": "x2"
            },
            "latitude2": {
              "field": "y2"
            }
          }
        },
        {
          "data": {
            "values": [
              {
                "lon": 153.2,
                "lat": -34.3,
                "label": "ACT"
              }
            ]
          },
          "mark": {
            "type": "text",
            "fontSize": 11,
            "fontWeight": 500,
            "color": "#555",
            "align": "left"
          },
          "encoding": {
            "longitude": {
              "field": "lon",
              "type": "quantitative"
            },
            "latitude": {
              "field": "lat",
              "type": "quantitative"
            },
            "text": {
              "field": "label"
            }
          }
        }
      ]
    },
    {
      "width": 150,
      "height": 200,
      "data": {
        "values": [
          {
            "sc": 0,
            "dc": 0,
            "color": "#E8DDF4"
          },
          {
            "sc": 0,
            "dc": 1,
            "color": "#C8B8D9"
          },
          {
            "sc": 0,
            "dc": 2,
            "color": "#9683B7"
          },
          {
            "sc": 1,
            "dc": 0,
            "color": "#D4C5DB"
          },
          {
            "sc": 1,
            "dc": 1,
            "color": "#A899B8"
          },
          {
            "sc": 1,
            "dc": 2,
            "color": "#7C6A98"
          },
          {
            "sc": 2,
            "dc": 0,
            "color": "#9D85B2"
          },
          {
            "sc": 2,
            "dc": 1,
            "color": "#735E8E"
          },
          {
            "sc": 2,
            "dc": 2,
            "color": "#3D2A60"
          }
        ]
      },
      "title": {
        "text": "Legend",
        "fontSize": 12,
        "anchor": "start",
        "color": "#555"
      },
      "mark": {
        "type": "rect",
        "stroke": "white",
        "strokeWidth": 1
      },
      "encoding": {
        "x": {
          "field": "sc",
          "type": "ordinal",
          "title": "Smoking",
          "axis": {
            "labelExpr": "datum.value == 0 ? 'Low' : datum.value == 1 ? 'Mid' : 'High'",
            "labelFontSize": 11,
            "labelAngle": 0,
            "titleFontSize": 11,
            "titlePadding": 8,
            "domain": false,
            "ticks": false,
            "orient": "bottom"
          }
        },
        "y": {
          "field": "dc",
          "type": "ordinal",
          "sort": "descending",
          "title": "Drinking",
          "axis": {
            "labelExpr": "datum.value == 0 ? 'Low' : datum.value == 1 ? 'Mid' : 'High'",
            "labelFontSize": 11,
            "titleFontSize": 11,
            "titlePadding": 8,
            "domain": false,
            "ticks": false
          }
        },
        "color": {
          "field": "color",
          "type": "nominal",
          "scale": null,
          "legend": null
        }
      }
    }
  ]
}