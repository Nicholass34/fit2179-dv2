{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Daily smoking is dying out",
    "subtitle": "Australians aged 14+ who smoke tobacco daily, 1991–2023",
    "anchor": "start",
    "fontSize": 20,
    "subtitleFontSize": 13,
    "subtitleColor": "#666",
    "offset": 20
  },
  "width": 700,
  "height": 380,
  "padding": {
    "left": 20,
    "right": 60,
    "top": 10,
    "bottom": 30
  },
  "background": "#FAFAF7",
  "config": {
    "view": {
      "stroke": null
    },
    "font": "Inter, system-ui, sans-serif"
  },
  "data": {
    "values": [
      {
        "year": 1991,
        "rate": 24.3
      },
      {
        "year": 1993,
        "rate": 25.0
      },
      {
        "year": 1995,
        "rate": 23.8
      },
      {
        "year": 1998,
        "rate": 21.8
      },
      {
        "year": 2001,
        "rate": 19.4
      },
      {
        "year": 2004,
        "rate": 17.5
      },
      {
        "year": 2007,
        "rate": 16.6
      },
      {
        "year": 2010,
        "rate": 15.1
      },
      {
        "year": 2013,
        "rate": 12.8
      },
      {
        "year": 2016,
        "rate": 12.2
      },
      {
        "year": 2019,
        "rate": 11.0
      },
      {
        "year": 2023,
        "rate": 8.3
      }
    ]
  },
  "encoding": {
    "x": {
      "field": "year",
      "type": "quantitative",
      "title": null,
      "scale": {
        "domain": [
          1989,
          2025
        ],
        "nice": false
      },
      "axis": {
        "values": [
          1991,
          1995,
          2000,
          2005,
          2010,
          2015,
          2020,
          2023
        ],
        "format": "d",
        "labelFontSize": 12,
        "labelColor": "#555",
        "labelFont": "Inter",
        "domain": false,
        "ticks": false,
        "labelPadding": 8
      }
    },
    "y": {
      "field": "rate",
      "type": "quantitative",
      "title": "Daily smokers (%)",
      "scale": {
        "domain": [
          0,
          28
        ]
      },
      "axis": {
        "values": [
          0,
          5,
          10,
          15,
          20,
          25
        ],
        "labelExpr": "datum.value + '%'",
        "labelFontSize": 12,
        "labelColor": "#555",
        "labelFont": "Inter",
        "titleFontSize": 12,
        "titleColor": "#333",
        "titleFont": "Inter",
        "titlePadding": 12,
        "grid": true,
        "gridColor": "#EEE",
        "gridDash": [
          2,
          2
        ],
        "domain": false,
        "ticks": false,
        "labelPadding": 8
      }
    }
  },
  "layer": [
    {
      "mark": {
        "type": "area",
        "color": "#888",
        "opacity": 0.08,
        "interpolate": "monotone",
        "line": false
      },
      "encoding": {}
    },
    {
      "mark": {
        "type": "line",
        "color": "#555",
        "strokeWidth": 2.5,
        "interpolate": "monotone"
      },
      "encoding": {
        "tooltip": [
          {
            "field": "year",
            "type": "quantitative",
            "title": "Year"
          },
          {
            "field": "rate",
            "type": "quantitative",
            "title": "Smoking rate (%)"
          }
        ]
      }
    },
    {
      "mark": {
        "type": "point",
        "filled": true,
        "color": "#555",
        "size": 60
      },
      "encoding": {}
    },
    {
      "transform": [
        {
          "filter": "datum.year == 1993"
        }
      ],
      "mark": {
        "type": "point",
        "filled": true,
        "color": "#C04040",
        "size": 140,
        "stroke": "#FAFAF7",
        "strokeWidth": 2
      },
      "encoding": {}
    },
    {
      "transform": [
        {
          "filter": "datum.year == 1993"
        }
      ],
      "mark": {
        "type": "text",
        "dx": 12,
        "dy": -12,
        "fontSize": 12,
        "fontWeight": 600,
        "color": "#C04040",
        "align": "left"
      },
      "encoding": {
        "text": {
          "value": "Peak: 25.0% (1993)"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.year == 2023"
        }
      ],
      "mark": {
        "type": "point",
        "filled": true,
        "color": "#1F7A3D",
        "size": 140,
        "stroke": "#FAFAF7",
        "strokeWidth": 2
      },
      "encoding": {}
    },
    {
      "transform": [
        {
          "filter": "datum.year == 2023"
        }
      ],
      "mark": {
        "type": "text",
        "dx": -12,
        "dy": -16,
        "fontSize": 12,
        "fontWeight": 600,
        "color": "#1F7A3D",
        "align": "right"
      },
      "encoding": {
        "text": {
          "value": "8.3% in 2022–23"
        }
      }
    },
    {
      "transform": [
        {
          "filter": "datum.year == 2023"
        }
      ],
      "mark": {
        "type": "text",
        "dx": -12,
        "dy": 0,
        "fontSize": 11,
        "color": "#1F7A3D",
        "align": "right"
      },
      "encoding": {
        "text": {
          "value": "Lowest on record"
        }
      }
    },
    {
      "data": {
        "values": [
          {
            "x": 2007,
            "y": 22,
            "txt": "Down 67% from peak"
          }
        ]
      },
      "mark": {
        "type": "text",
        "fontSize": 14,
        "fontWeight": 500,
        "color": "#333",
        "align": "center"
      },
      "encoding": {
        "x": {
          "field": "x",
          "type": "quantitative"
        },
        "y": {
          "field": "y",
          "type": "quantitative"
        },
        "text": {
          "field": "txt"
        }
      }
    }
  ]
}